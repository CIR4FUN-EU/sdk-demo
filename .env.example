# Real DPP services (required)
DPP_REPO_BASE_URL=http://localhost:8080
DPP_REGISTRY_BASE_URL=http://localhost:8081
DPP_OPERATOR_ID=exampleOperator123

# EDC data-space connector
EDC_HOST=http://localhost
EDC_ASSET_ID=demo-asset

# EDC data-space connector
# MANAGEMENT: hit from the host, so localhost + the published compose port.
# PROTOCOL: hit container-to-container during negotiation, so the compose service name.
PROVIDER_MANAGEMENT=http://localhost:19193/management
PROVIDER_PROTOCOL=http://provider:19194/protocol/2025-1
PROVIDER_ID=provider

CONSUMER_MANAGEMENT=http://localhost:29193/management
CONSUMER_PROTOCOL=http://consumer:29194/protocol/2025-1
CONSUMER_ID=consumer
